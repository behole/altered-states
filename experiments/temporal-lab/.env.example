# Copy to .env and fill in your key.
# Get an OpenRouter key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-...

# Default model. Override per-run with `--model` or change here.
# OpenRouter model IDs: https://openrouter.ai/models
# Picks worth trying:
#   anthropic/claude-sonnet-4.6   — balanced default (writing quality / cost)
#   anthropic/claude-haiku-4.5    — budget knob
#   anthropic/claude-opus-4.6     — top quality, ~5x cost
#   openai/gpt-5                  — strong alt voice
#   google/gemini-2.5-pro         — alt long-context
#   deepseek/deepseek-v3          — cheap, good for high-volume runs
TEMPORAL_LAB_MODEL=anthropic/claude-sonnet-4.6

# Optional: where the lab stores characters/journals/logs.
# Default is experiments/temporal-lab/runtime/ (gitignored, repo-local).
# ALTERED_STATES_TEMPORAL_PATH=~/.altered-states/temporal-lab

# Optional: dry-run mode skips real API calls and writes a deterministic
# stub response. Useful for verifying wiring without burning tokens.
# TEMPORAL_LAB_DRY_RUN=1
